        "vue": "^3.4.27",
        "vue-chartjs": "^5.3.1",
        "vue-router": "^4.3.3"
    },
    "devDependencies": {
        "@types/node": "^20.14.2",
        "@typescript-eslint/eslint-plugin": "^7.14.1",
        "@vitejs/plugin-vue": "^5.0.5",
        "@vue/tsconfig": "^0.5.1",
        "eslint": "^9.6.0",
